<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Purpura" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/purpura_primary</item>
        <item name="colorOnPrimary">@color/purpura_on_primary</item>
        <item name="colorPrimaryContainer">@color/purpura_primary_container</item>
        <item name="colorOnPrimaryContainer">@color/purpura_on_primary_container</item>
        <item name="colorSecondary">@color/purpura_secondary</item>
        <item name="colorOnSecondary">@color/purpura_on_secondary</item>
        <item name="colorSecondaryContainer">@color/purpura_secondary_container</item>
        <item name="colorOnSecondaryContainer">@color/purpura_on_secondary_container</item>
        <item name="colorTertiary">@color/purpura_tertiary</item>
        <item name="colorOnTertiary">@color/purpura_on_tertiary</item>
        <item name="colorTertiaryContainer">@color/purpura_tertiary_container</item>
        <item name="colorOnTertiaryContainer">@color/purpura_on_tertiary_container</item>
        <item name="colorError">@color/purpura_error</item>
        <item name="colorOnError">@color/purpura_on_error</item>
        <item name="colorErrorContainer">@color/purpura_error_container</item>
        <item name="colorOnErrorContainer">@color/purpura_on_error_container</item>
        <item name="android:colorBackground">@color/purpura_background</item>
        <item name="colorOnBackground">@color/purpura_on_background</item>
        <item name="colorSurface">@color/purpura_surface</item>
        <item name="colorOnSurface">@color/purpura_on_surface</item>
        <item name="colorSurfaceVariant">@color/purpura_surface_variant</item>
        <item name="colorOnSurfaceVariant">@color/purpura_on_surface_variant</item>
        <item name="colorOutline">@color/purpura_outline</item>
        <item name="colorOutlineVariant">@color/purpura_outline_variant</item>
        <!-- Edge-to-edge: barras transparentes manejadas por enableEdgeToEdge() en MainActivity.
             En Android 15 statusBarColor/navigationBarColor estan obsoletos (ignorados). Sin el
             DrawerLayout ya no se pinta el scrim morado que invadia la status bar. Desactivamos el
             forzado de contraste para que las barras queden limpias; el color de los iconos lo fija
             PurpuraTheme segun claro/oscuro. -->
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:enforceStatusBarContrast">false</item>
        <item name="android:enforceNavigationBarContrast">false</item>

        <!-- Forma global -->
        <item name="shapeAppearanceSmallComponent">@style/ShapeAppearance.Purpura.Pill</item>
        <item name="shapeAppearanceMediumComponent">@style/ShapeAppearance.Purpura.Medium</item>
        <item name="shapeAppearanceLargeComponent">@style/ShapeAppearance.Purpura.Large</item>

        <!-- Estilos por defecto pill -->
        <item name="materialButtonStyle">@style/Widget.Purpura.Button</item>
        <item name="chipStyle">@style/Widget.Purpura.Chip</item>
        <item name="textInputStyle">@style/Widget.Purpura.TextInputLayout</item>
        <item name="floatingActionButtonStyle">@style/Widget.Purpura.FAB</item>
        <item name="extendedFloatingActionButtonStyle">@style/Widget.Purpura.ExtendedFAB</item>

        <!-- Tipografia cableada al tema: punto unico de palanca de marca. Hoy es passthrough
             (TextAppearance.Purpura.* hereda M3 identico), pero permite inyectar la fuente de
             marca en un solo lugar sin tocar cada layout. -->
        <item name="textAppearanceDisplaySmall">@style/TextAppearance.Purpura.DisplaySmall</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.Purpura.HeadlineMedium</item>
        <item name="textAppearanceHeadlineSmall">@style/TextAppearance.Purpura.HeadlineSmall</item>
        <item name="textAppearanceTitleLarge">@style/TextAppearance.Purpura.TitleLarge</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.Purpura.TitleMedium</item>
        <item name="textAppearanceTitleSmall">@style/TextAppearance.Purpura.TitleSmall</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.Purpura.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.Purpura.BodyMedium</item>
        <item name="textAppearanceBodySmall">@style/TextAppearance.Purpura.BodySmall</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.Purpura.LabelLarge</item>
        <item name="textAppearanceLabelMedium">@style/TextAppearance.Purpura.LabelMedium</item>
        <item name="textAppearanceLabelSmall">@style/TextAppearance.Purpura.LabelSmall</item>
    </style>
</resources>
