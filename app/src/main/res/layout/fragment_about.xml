<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="@dimen/space_xxl">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:contentDescription="@string/about_app_name"
            android:src="@drawable/ic_launcher_foreground"
            android:background="@color/purpura_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:text="@string/about_app_name"
            android:textAppearance="@style/TextAppearance.Purpura.HeadlineMedium"
            android:textColor="@color/purpura_on_primary_container" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:text="@string/about_version"
            android:textAppearance="@style/TextAppearance.Purpura.BodyLarge"
            android:textColor="@color/purpura_on_surface_variant" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_lg"
            android:gravity="center"
            android:text="@string/about_credits"
            android:textAppearance="@style/TextAppearance.Purpura.BodyMedium"
            android:textColor="@color/purpura_on_surface" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/logoutButton"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xxl"
            android:text="@string/about_logout"
            app:icon="@drawable/ic_logout"
            app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Purpura.Pill" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
