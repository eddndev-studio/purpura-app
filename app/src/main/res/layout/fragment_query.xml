<?xml version="1.0" encoding="utf-8"?>
<!-- Consultar: barra de filtros (periodo / tipo / estatus) sobre la lista de resultados. Los
     filtros aplican al cambiar; el modo Día/Rango abre un selector de fecha. La lista reusa
     item_event y navega al Detalle al tocar una tarjeta. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/space_md"
        android:paddingTop="@dimen/space_sm">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/query_period_label"
            android:textAppearance="@style/TextAppearance.Purpura.LabelMedium"
            android:textColor="@color/purpura_on_surface_variant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/modeChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModeAll"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModeDay"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_mode_day" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModeRange"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_mode_range" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModeMonth"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_mode_month" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModeYear"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/query_mode_year" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/dateButton"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/query_pick_day"
            android:visibility="gone"
            app:icon="@drawable/ic_calendar_month"
            app:shapeAppearance="@style/ShapeAppearance.Purpura.Pill"
            tools:visibility="visible" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/query_type_label"
            android:textAppearance="@style/TextAppearance.Purpura.LabelMedium"
            android:textColor="@color/purpura_on_surface_variant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/typeChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeAll"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeCita"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_cita" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeJunta"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_junta" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeEntrega"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_entrega_proyecto" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeExamen"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_examen" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipTypeOtros"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_otros" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:text="@string/query_status_label"
            android:textAppearance="@style/TextAppearance.Purpura.LabelMedium"
            android:textColor="@color/purpura_on_surface_variant" />

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/statusChipGroup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:selectionRequired="true"
                app:singleLine="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusAll"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/filter_all" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusPendiente"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_status_pendiente" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusRealizado"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_status_realizado" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipStatusAplazado"
                    style="@style/Widget.Purpura.Chip"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_status_aplazado" />
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/space_sm"
        android:layout_weight="1">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/resultsRecycler"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:contentDescription="@string/query_results_desc"
            android:paddingBottom="@dimen/space_md"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
            tools:listitem="@layout/item_event" />

        <LinearLayout
            android:id="@+id/emptyGroup"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="@dimen/space_md"
            android:visibility="gone"
            tools:visibility="visible">

            <ImageView
                android:layout_width="96dp"
                android:layout_height="96dp"
                android:alpha="0.38"
                android:contentDescription="@string/placeholder_icon_desc"
                android:src="@drawable/ic_search"
                app:tint="@color/purpura_primary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_md"
                android:gravity="center"
                android:text="@string/query_empty_title"
                android:textAppearance="@style/TextAppearance.Purpura.TitleMedium"
                android:textColor="@color/purpura_on_surface" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/space_xs"
                android:gravity="center"
                android:text="@string/query_empty_body"
                android:textAppearance="@style/TextAppearance.Purpura.BodyMedium"
                android:textColor="@color/purpura_on_surface_variant" />
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />

        <ProgressBar
            android:id="@+id/pagingProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/space_md"
            android:indeterminate="true"
            android:visibility="gone"
            tools:visibility="visible" />
    </FrameLayout>
</LinearLayout>
