<?xml version="1.0" encoding="utf-8"?>
<!-- Tarjeta de un evento en la lista de Inicio. Las etiquetas de tipo/estatus y el texto de
     fecha/hora se resuelven en HomeEventAdapter; aqui solo se declara la estructura. -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/eventCard"
    style="@style/Widget.Purpura.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/space_md"
    android:layout_marginTop="@dimen/list_item_spacing"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/space_md">

        <TextView
            android:id="@+id/dateText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:maxLines="1"
            android:ellipsize="end"
            android:textAppearance="@style/TextAppearance.Purpura.LabelLarge"
            android:textColor="@color/purpura_primary"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Hoy · 15:30" />

        <TextView
            android:id="@+id/descriptionText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="2"
            android:textAppearance="@style/TextAppearance.Purpura.TitleMedium"
            android:textColor="@color/purpura_on_surface"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/dateText"
            tools:text="Revisión de avance del proyecto final" />

        <TextView
            android:id="@+id/contactText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_xs"
            android:ellipsize="end"
            android:maxLines="1"
            android:textAppearance="@style/TextAppearance.Purpura.BodySmall"
            android:textColor="@color/purpura_on_surface_variant"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/descriptionText"
            tools:text="María González" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/space_sm"
            android:orientation="horizontal"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/contactText">

            <TextView
                android:id="@+id/typeBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_pill_badge"
                android:minHeight="0dp"
                android:paddingHorizontal="@dimen/space_sm"
                android:paddingVertical="@dimen/space_xxs"
                android:textAppearance="@style/TextAppearance.Purpura.LabelSmall"
                tools:backgroundTint="@color/event_junta_container"
                tools:text="Junta"
                tools:textColor="@color/event_junta" />

            <TextView
                android:id="@+id/statusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/space_xs"
                android:background="@drawable/bg_pill_badge"
                android:minHeight="0dp"
                android:paddingHorizontal="@dimen/space_sm"
                android:paddingVertical="@dimen/space_xxs"
                android:textAppearance="@style/TextAppearance.Purpura.LabelSmall"
                tools:backgroundTint="@color/status_pendiente_container"
                tools:text="Pendiente"
                tools:textColor="@color/status_pendiente" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
