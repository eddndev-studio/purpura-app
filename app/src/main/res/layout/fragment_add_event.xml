<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ui.addevent.AddEventFragment">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Descripcion -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/descriptionLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="@string/add_event_description_label">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/descriptionInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences|textMultiLine"
                    android:minLines="2"
                    android:maxLines="4" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Contacto (REQ-ADD-002): se elige SIEMPRE de la lista del telefono. El campo es de solo
                 lectura (focusable=false) y abre el selector al tocarlo; no se escribe a mano. -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/contactLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/add_event_contact_label"
                app:helperText="@string/add_event_contact_helper"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/contactInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:cursorVisible="false"
                    android:focusable="false"
                    android:inputType="none"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pickContactButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/add_event_pick_contact"
                app:icon="@android:drawable/ic_menu_call"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Purpura.Pill" />

            <TextView
                android:id="@+id/contactLinked"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:text="@string/add_event_contact_linked"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:visibility="gone"
                app:drawableStartCompat="@android:drawable/ic_menu_call"
                tools:visibility="visible" />

            <!-- Lugar (solo etiqueta por ahora; el selector de mapa llega con el billing de Maps) -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/placeLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:hint="@string/add_event_place_label"
                app:helperText="@string/add_event_place_helper"
                app:helperTextEnabled="true">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/placeInput"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapSentences"
                    android:maxLines="1" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/pickLocationButton"
                style="?attr/materialButtonOutlinedStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="@string/add_event_pick_location"
                app:icon="@android:drawable/ic_dialog_map"
                app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Purpura.Pill" />

            <TextView
                android:id="@+id/locationSelected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:drawablePadding="6dp"
                android:gravity="center_vertical"
                android:text="@string/add_event_location_selected"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:visibility="gone"
                app:drawableStartCompat="@android:drawable/ic_menu_mylocation"
                tools:visibility="visible" />

            <!-- Tipo -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/add_event_type_label"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/typeChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddTypeCita"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/event_type_cita" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddTypeJunta"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_junta" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddTypeEntrega"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_entrega_proyecto" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddTypeExamen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_examen" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddTypeOtros"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/event_type_otros" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Fecha y hora -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:baselineAligned="false"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_event_date_label"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/dateButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/add_event_pick_date"
                        app:icon="@android:drawable/ic_menu_my_calendar"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Purpura.Pill" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/add_event_time_label"
                        android:textAppearance="?attr/textAppearanceTitleSmall" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/timeButton"
                        style="?attr/materialButtonOutlinedStyle"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="@string/add_event_pick_time"
                        app:icon="@android:drawable/ic_menu_recent_history"
                        app:shapeAppearanceOverlay="@style/ShapeAppearanceOverlay.Purpura.Pill" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/dateTimeError"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="?attr/colorError"
                android:visibility="gone"
                tools:text="@string/add_event_error_datetime"
                tools:visibility="visible" />

            <!-- Estatus. En modo edicion se oculta (statusSection): el Detalle ya es el dueno del
                 estatus via su propio endpoint, asi el PATCH del formulario queda solo de campos. -->
            <LinearLayout
                android:id="@+id/statusSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/add_event_status_label"
                    android:textAppearance="?attr/textAppearanceTitleSmall" />

                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/statusChipGroup"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    app:selectionRequired="true"
                    app:singleSelection="true">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAddStatusPendiente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checked="true"
                        android:text="@string/event_status_pendiente" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAddStatusRealizado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/event_status_realizado" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chipAddStatusAplazado"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/event_status_aplazado" />
                </com.google.android.material.chip.ChipGroup>
            </LinearLayout>

            <!-- Recordatorio -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:text="@string/add_event_reminder_label"
                android:textAppearance="?attr/textAppearanceTitleSmall" />

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/reminderChipGroup"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:selectionRequired="true"
                app:singleSelection="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddReminderNone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:checked="true"
                    android:text="@string/reminder_none" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddReminderAtTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reminder_at_time" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddReminderTen"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reminder_ten_minutes_before" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipAddReminderDay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/reminder_one_day_before" />
            </com.google.android.material.chip.ChipGroup>

            <!-- Guardar -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/saveButton"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                android:text="@string/add_event_save" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/savingProgress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="16dp"
                android:indeterminate="true"
                android:visibility="gone"
                tools:visibility="visible" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</FrameLayout>
