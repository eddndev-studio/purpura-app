<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Notificaciones locales de recordatorio (runtime en API 33+). -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <!-- Alarmas EXACTAS: el recordatorio debe disparar a la hora aun en Doze. USE_EXACT_ALARM
         (API 33+) se auto-concede a apps cuya funcion central son recordatorios/alarmas, como
         Purpura; SCHEDULE_EXACT_ALARM cubre API 31-32. -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" android:maxSdkVersion="32" />
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />
    <!-- Selector de contacto del evento (REQ-ADD-002): se pide en runtime al elegir contacto para
         leer su telefono de la tabla Phone. Si se niega, el nombre se escribe a mano. -->
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <application
        android:name=".PurpuraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Purpura">

        <!-- Maps SDK for Android. La key la inyecta el build desde local.properties/env (placeholder
             MAPS_API_KEY); si esta vacia el mapa no renderiza pero la app no rompe. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Purpura">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Recibe la alarma del recordatorio y publica la notificacion (REQ-NOTIF-001). No
             exportado: solo lo dispara el AlarmManager de la propia app. -->
        <receiver
            android:name=".data.reminder.ReminderReceiver"
            android:exported="false" />
    </application>
</manifest>
