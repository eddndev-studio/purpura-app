<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <!-- Notificaciones locales de recordatorio (runtime en API 33+). Alarmas inexactas: no se
         requiere SCHEDULE_EXACT_ALARM. -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:name=".PurpuraApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:networkSecurityConfig="@xml/network_security_config"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Purpura">

        <!-- Maps SDK for Android. La key la inyecta el build desde local.properties/env (placeholder
             MAPS_API_KEY); si esta vacia el mapa no renderiza pero la app no rompe. -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="${MAPS_API_KEY}" />

        <activity
            android:name=".ui.MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Purpura">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Recibe la alarma del recordatorio y publica la notificacion (REQ-NOTIF-001). No
             exportado: solo lo dispara el AlarmManager de la propia app. -->
        <receiver
            android:name=".data.reminder.ReminderReceiver"
            android:exported="false" />
    </application>
</manifest>
